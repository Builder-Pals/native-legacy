{
    "name": "nl-layer",
    "emitLegacyScripts": false,
    "tree": {
        "$className": "DataModel",

        "ReplicatedStorage": {
            "$className": "ReplicatedStorage",

            "native_legacy": {
                "$path": "dist/"
            },

            "server": {
                "$className": "Script",
                "$properties": {
                    "RunContext": "Server",
                    "Source": "require(game:GetService('ReplicatedStorage').native_legacy).boot()"
                }
            },

            "client": {
                "$className": "Script",
                "$properties": {
                    "RunContext": "Client",
                    "Source": "require(game:GetService('ReplicatedStorage').native_legacy).boot()"
                }
            }
        }
    }
}